    echo -e "${BOLD}${WHITE}Parameters${OFF}"
    echo -e "  * ${GREEN}start${OFF} ${BLUE}[string]${OFF} ${CYAN}(default: null)${OFF} - Lower bound (inclusive), 'YYYY-MM-DD'.${YELLOW} Specify as: start=value${OFF}" \
        | paste -sd' ' | fold -sw 80 | sed '2,$s/^/    /'
    echo -e "  * ${GREEN}end${OFF} ${BLUE}[string]${OFF} ${CYAN}(default: null)${OFF} - Upper bound (inclusive), 'YYYY-MM-DD'.${YELLOW} Specify as: end=value${OFF}" \
        | paste -sd' ' | fold -sw 80 | sed '2,$s/^/    /'
