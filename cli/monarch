      history)
        [[ -z "${1:-}" ]] && { echo "holding history <id> [--start --end]" >&2; exit 2; }
        HID="$1"; shift
        START=""; END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            *) echo "holding history: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        call GET "/v1/holdings/$HID/history${q:+?${q:1}}" \
          | emit '.data.history[] | [.date, ((.value // 0)|tostring), ((.quantity // 0)|tostring)] | @tsv' \
          | fmt_table
        ;;
      add)
        [[ -z "${1:-}" ]] && { echo "holding add <account-id> --security-id ID --quantity Q" >&2; exit 2; }
        AID="$1"; shift
        SID=""; QTY=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --security-id) SID="$2"; shift 2 ;;
            --quantity) QTY="$2"; shift 2 ;;
            *) echo "holding add: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$SID" || -z "$QTY" ]] && {
          echo "holding add requires --security-id --quantity" >&2; exit 2;
        }
        body=$(jq -n --arg s "$SID" --argjson q "$QTY" '{securityId:$s, quantity:$q}')
        call POST "/v1/account/$AID/holdings" "$body" | emit ".data"
        ;;
      update)
        [[ -z "${1:-}" ]] && { echo "holding update <id> [--quantity Q] [--security-type T] [--basis X]" >&2; exit 2; }
        HID="$1"; shift
        QTY=""; SEC_TYPE=""; BASIS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --quantity) QTY="$2"; shift 2 ;;
            --security-type) SEC_TYPE="$2"; shift 2 ;;
            --basis) BASIS="$2"; shift 2 ;;
            *) echo "holding update: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        body=$(jq -n --arg q "$QTY" --arg st "$SEC_TYPE" --arg b "$BASIS" \
          '{quantity:      (if $q  == "" then null else ($q|tonumber) end),
            securityType:  (if $st == "" then null else $st end),
            userCostBasis: (if $b  == "" then null else ($b|tonumber) end)}
           | with_entries(select(.value != null))')
        call PATCH "/v1/holdings/$HID" "$body" | emit ".data"
        ;;
      delete)
        [[ -z "${1:-}" ]] && { echo "holding delete <id> [--yes]" >&2; exit 2; }
        HID="$1"; shift
        [[ "${1:-}" == "--yes" ]] && YES=1
        confirm "Delete holding $HID?"
        call DELETE "/v1/holdings/$HID" | emit ".data"
        ;;
      *) echo "holding subcommands: history | add | update | delete" >&2; exit 2 ;;
    esac
    ;;

  # ---------------------------------------------------------------------------
  # Read: lookup, balance-at, recap, insights, attachment, credentials,
  #        portfolio, security
  # ---------------------------------------------------------------------------
  lookup)
    [[ -z "${2:-}" ]] && { echo "monarch lookup <query>" >&2; exit 2; }
    Q="$2"
    path="/v1/lookup?q=$(_urlenc "$Q")"
    call GET "$path" \
      | emit '.data.results[] | [(.type // "-"), (.id // "-"), (.name // "-")] | @tsv' \
      | fmt_table
    ;;

  balance-at)
    [[ -z "${2:-}" ]] && { echo "monarch balance-at <account-id> --date YYYY-MM-DD" >&2; exit 2; }
    AID="$2"; shift 2
    DATE=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --date) DATE="$2"; shift 2 ;;
        *) echo "balance-at: unknown flag: $1" >&2; exit 2 ;;
      esac
    done
    [[ -z "$DATE" ]] && { echo "balance-at requires --date YYYY-MM-DD" >&2; exit 2; }
    call GET "/v1/accounts/$AID/balance/at?date=$DATE" \
      | emit '.data | "id=\(.id)  displayBalance=\(.displayBalance // "-")  includeInNetWorth=\(.includeInNetWorth)"'
    ;;

  recap)
    sub="${2:-}"
    [[ -z "$sub" ]] && { echo "monarch recap <weekly> [args]" >&2; exit 2; }
    case "$sub" in
      weekly)
        shift 2
        START=""; END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            *) echo "recap weekly: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$START" || -z "$END" ]] && {
          echo "recap weekly requires --start YYYY-MM-DD --end YYYY-MM-DD" >&2; exit 2;
        }
        call GET "/v1/recap/weekly?start=$START&end=$END" \
          | emit '.data.recap | if . == null then "no recap generated for this week yet" else "id=\(.id)  range=\(.dateRangeStart)..\(.dateRangeEnd)  sentiment=\(.sentiment // "-")\n\n\(.summary // "(no summary)")" end'
        ;;
      *) echo "recap subcommands: weekly" >&2; exit 2 ;;
    esac
    ;;

  insights)
    case "${2:-}" in
      latest-run)
        call GET /v1/insights/latest-run \
          | emit '.data | "insightsCount=\(.insightsCount // "-")  latestRun=\(.latestRun // {} | "id=\(.id // "-") status=\(.status // "-") generated=\(.insightsGeneratedCount // "-") error=\(.errorMessage // "-")")"'
        ;;
      *)
        shift
        STATUS_VALS=""; S_START=""; S_END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --status) STATUS_VALS="${STATUS_VALS:+$STATUS_VALS }$2"; shift 2 ;;
            --start) S_START="$2"; shift 2 ;;
            --end) S_END="$2"; shift 2 ;;
            *) echo "insights: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        if [[ -n "$STATUS_VALS" ]]; then
          for s in $STATUS_VALS; do q+="&status=$s"; done
        fi
        [[ -n "$S_START" ]] && q+="&summaryStart=$S_START"
        [[ -n "$S_END" ]] && q+="&summaryEnd=$S_END"
        path="/v1/insights${q:+?${q:1}}"
        call GET "$path" \
          | emit '.data.insights[] | [(.id // "-"), (.status // "-"), (.merchantNameDisplay // .dashboardSubtitle // "-"), ((.annualSavingsEstimateMin // 0)|tostring), ((.annualSavingsEstimateMax // 0)|tostring)] | @tsv' \
          | fmt_table
        ;;
    esac
    ;;

  insight)
    [[ -z "${2:-}" ]] && { echo "monarch insight <id>" >&2; exit 2; }
    call GET "/v1/insights/$2" | emit '.data.insight'
    ;;

  attachment)
    [[ -z "${2:-}" ]] && { echo "monarch attachment <id>" >&2; exit 2; }
    call GET "/v1/attachments/$2" \
      | emit '.data.attachment | "id=\(.id)  url=\(.originalAssetUrl // "-")"'
    ;;

  credentials)
    case "${2:-}" in
      with-institutions)
        call GET /v1/credentials/institutions \
          | emit '.data.credentials[] | [(.credentialId // "-"), (.name // "-"), (.preferredDataProvider // "-"), (.plaidInstitutionId // "-")] | @tsv' \
          | fmt_table
        ;;
      *)
        call GET /v1/credentials \
          | emit '.data.credentials[] | [(.id // "-"), (.institutionName // "-"), (.institutionId // "-")] | @tsv' \
          | fmt_table
        ;;
    esac
    ;;

  tax)
    sub="${2:-}"
    [[ -z "$sub" ]] && { echo "monarch tax <categories|aggregates|mappings> [args]" >&2; exit 2; }
    case "$sub" in
      categories)
        call GET /v1/tax/categories \
          | emit '.data.categories[] | [(.id // "-"), (.name // "-"), (.systemCategory // "-")] | @tsv' \
          | fmt_table
        ;;
      aggregates)
        shift 2
        START=""; END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            *) echo "tax aggregates: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        path="/v1/tax/category-aggregates${q:+?${q:1}}"
        call GET "$path" \
          | emit '.data.rows[] | [(.category.id // "-"), (.category.name // "-"), (.category.systemCategory // "-"), ((.sum // 0)|tostring), ((.count // 0)|tostring)] | @tsv' \
          | fmt_table
        ;;
      mappings)
        shift 2
        SCHEDULE=""; YEAR=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --schedule) SCHEDULE="$2"; shift 2 ;;
            --tax-year|--year) YEAR="$2"; shift 2 ;;
            *) echo "tax mappings: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$SCHEDULE" || -z "$YEAR" ]] && { echo "tax mappings requires --schedule S --tax-year YYYY" >&2; exit 2; }
        path="/v1/tax/schedule-mappings?schedule=$SCHEDULE&taxYear=$YEAR"
        call GET "$path" \
          | emit '.data.mappings[] | [(.id // "-"), (.lineItem // "-"), (.lineItemInfo.lineNumber // "-"), (.category.id // "-"), (.category.name // "-")] | @tsv' \
          | fmt_table
        ;;
      *)
        echo "monarch tax <categories|aggregates|mappings> [args]" >&2; exit 2
        ;;
    esac
    ;;

  portfolio)
    sub="${2:-}"
    [[ -z "$sub" ]] && { echo "monarch portfolio <allocation> [args]" >&2; exit 2; }
    case "$sub" in
      allocation)
        sub2="${3:-}"
        case "$sub2" in
          by-account)
            shift 3
            ACCOUNT_IDS=""; LIMIT=""
            while [[ $# -gt 0 ]]; do
              case "$1" in
                --account) ACCOUNT_IDS="${ACCOUNT_IDS:+$ACCOUNT_IDS }$2"; shift 2 ;;
                --limit) LIMIT="$2"; shift 2 ;;
                *) echo "portfolio allocation by-account: unknown flag: $1" >&2; exit 2 ;;
              esac
            done
            q=""
            if [[ -n "$ACCOUNT_IDS" ]]; then
              for id in $ACCOUNT_IDS; do q+="&accountIds=$id"; done
            fi
            [[ -n "$LIMIT" ]] && q+="&limit=$LIMIT"
            path="/v1/portfolio/allocation/by-account${q:+?${q:1}}"
            call GET "$path" \
              | emit '.data.buckets[] | [(.typeDisplay // .type), ((.allocationPercent // 0)|tostring), ((.totalValue // 0)|tostring)] | @tsv' \
              | fmt_table
            ;;
          by-holdings)
            shift 3
            ACCOUNT_IDS=""; LIMIT=""
            while [[ $# -gt 0 ]]; do
              case "$1" in
                --account) ACCOUNT_IDS="${ACCOUNT_IDS:+$ACCOUNT_IDS }$2"; shift 2 ;;
                --limit) LIMIT="$2"; shift 2 ;;
                *) echo "portfolio allocation by-holdings: unknown flag: $1" >&2; exit 2 ;;
              esac
            done
            q=""
            if [[ -n "$ACCOUNT_IDS" ]]; then
              for id in $ACCOUNT_IDS; do q+="&accountIds=$id"; done
            fi
            [[ -n "$LIMIT" ]] && q+="&limit=$LIMIT"
            path="/v1/portfolio/allocation/by-holdings${q:+?${q:1}}"
            call GET "$path" \
              | emit '.data.buckets[] | [(.typeDisplay // .type), ((.allocationPercent // 0)|tostring), ((.totalValue // 0)|tostring)] | @tsv' \
              | fmt_table
            ;;
          holdings-detail)
            shift 3
            ACCOUNT_IDS=""; CLASS_F=""; CLASS_V=""; LIMIT=""; OFFSET=""
            while [[ $# -gt 0 ]]; do
              case "$1" in
                --account) ACCOUNT_IDS="${ACCOUNT_IDS:+$ACCOUNT_IDS }$2"; shift 2 ;;
                --classification) CLASS_F="$2"; shift 2 ;;
                --value) CLASS_V="$2"; shift 2 ;;
                --limit) LIMIT="$2"; shift 2 ;;
                --offset) OFFSET="$2"; shift 2 ;;
                *) echo "portfolio allocation holdings-detail: unknown flag: $1" >&2; exit 2 ;;
              esac
            done
            [[ -z "$CLASS_F" || -z "$CLASS_V" ]] && {
              echo "portfolio allocation holdings-detail requires --classification FIELD --value VAL" >&2; exit 2;
            }
            q="&classificationField=$CLASS_F&classificationValue=$(_urlenc "$CLASS_V")"
            if [[ -n "$ACCOUNT_IDS" ]]; then
              for id in $ACCOUNT_IDS; do q+="&accountIds=$id"; done
            fi
            [[ -n "$LIMIT" ]] && q+="&limit=$LIMIT"
            [[ -n "$OFFSET" ]] && q+="&offset=$OFFSET"
            path="/v1/portfolio/allocation/holdings-detail?${q:1}"
            call GET "$path" \
              | emit '.data.holdings[] | [(.ticker // "-"), .securityName, ((.quantity // 0)|tostring), ((.value // 0)|tostring)] | @tsv' \
              | fmt_table
            ;;
          *)
            # Default: top-level allocation by classification
            shift 2
            ACCOUNT_IDS=""; CLASS_F=""
            while [[ $# -gt 0 ]]; do
              case "$1" in
                --account) ACCOUNT_IDS="${ACCOUNT_IDS:+$ACCOUNT_IDS }$2"; shift 2 ;;
                --classification) CLASS_F="$2"; shift 2 ;;
                *) echo "portfolio allocation: unknown flag: $1" >&2; exit 2 ;;
              esac
            done
            q=""
            if [[ -n "$ACCOUNT_IDS" ]]; then
              for id in $ACCOUNT_IDS; do q+="&accountIds=$id"; done
            fi
            [[ -n "$CLASS_F" ]] && q+="&classificationField=$CLASS_F"
            path="/v1/portfolio/allocation${q:+?${q:1}}"
            # Two-pass emit: header line, then a TSV table of buckets.
            resp=$(call GET "$path")
            if [[ "$RAW" == "1" ]]; then
              printf '%s' "$resp"
            else
              printf '%s\n' "$resp" | jq -r '"totalValue=\(.data.totalValue // "-")"'
              printf '%s\n' "$resp" | jq -r '.data.buckets[] | [(.typeDisplay // .type), ((.allocationPercent // 0)|tostring), ((.totalValue // 0)|tostring)] | @tsv' | column -t -s $'\t'
            fi
            ;;
        esac
        ;;
      *) echo "portfolio subcommands: allocation [by-account|by-holdings|holdings-detail]" >&2; exit 2 ;;
    esac
    ;;

  security)
    sub="${2:-}"
    [[ -z "$sub" ]] && { echo "monarch security <performance> [args]" >&2; exit 2; }
    case "$sub" in
      performance)
        [[ -z "${3:-}" ]] && { echo "security performance <id> [--start --end]" >&2; exit 2; }
        SID="$3"; shift 3
        START=""; END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            *) echo "security performance: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        path="/v1/securities/$SID/performance${q:+?${q:1}}"
        resp=$(call GET "$path")
        if [[ "$RAW" == "1" ]]; then
          printf '%s' "$resp"
        else
          printf '%s\n' "$resp" | jq -r '.data | "currentPrice=\(.security.currentPrice // "-")  closingPrice=\(.security.closingPrice // "-")  points=\(.chart | length)"'
          printf '%s\n' "$resp" | jq -r '.data.chart[] | [.date, ((.returnPercent // 0)|tostring), ((.value // 0)|tostring)] | @tsv' | column -t -s $'\t'
        fi
        ;;
      details)
        [[ -z "${3:-}" ]] && { echo "security details <id>" >&2; exit 2; }
        call GET "/v1/securities/$3" \
          | emit '.data.security | "id=\(.id)  ticker=\(.ticker // "-")  name=\(.name // "-")  type=\(.type // "-")  currentPrice=\(.currentPrice // "-")"'
        ;;
      dividends)
        [[ -z "${3:-}" ]] && { echo "security dividends <id>" >&2; exit 2; }
        call GET "/v1/securities/$3/dividends" \
          | emit '.data.dividends[] | [.exDate, ((.amount // 0)|tostring), (.frequency // "-")] | @tsv' \
          | fmt_table
        ;;
      *) echo "security subcommands: performance|details|dividends" >&2; exit 2 ;;
    esac
    ;;

  # ---------------------------------------------------------------------------
  # Reports family (post-180 expansion)
  # ---------------------------------------------------------------------------
  reports)
    sub="${2:-}"
    [[ -z "$sub" ]] && { echo "monarch reports <spending|income|net-worth|savings-rate|monthly-summary> [args]" >&2; exit 2; }
    case "$sub" in
      spending|income|net-worth|savings-rate|monthly-summary)
        path_seg="/v1/reports/$sub"
        shift 2
        START=""; END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            *) echo "reports $sub: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        call GET "${path_seg}${q:+?${q:1}}" | emit '.data'
        ;;
      *) echo "reports subcommands: spending|income|net-worth|savings-rate|monthly-summary" >&2; exit 2 ;;
    esac
    ;;

  calendar)
    [[ "${2:-}" != "events" ]] && { echo "monarch calendar events [--start --end]" >&2; exit 2; }
    shift 2
    START=""; END=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --start) START="$2"; shift 2 ;;
        --end) END="$2"; shift 2 ;;
        *) echo "calendar events: unknown flag: $1" >&2; exit 2 ;;
      esac
    done
    q=""
    [[ -n "$START" ]] && q+="&start=$START"
    [[ -n "$END" ]] && q+="&end=$END"
    call GET "/v1/calendar/events${q:+?${q:1}}" \
      | emit '.data.events[] | [.date, (.type // "-"), (.name // "-"), ((.amount // 0)|tostring)] | @tsv' \
      | fmt_table
    ;;

  *)
    echo "monarch: unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
