        ;;
      reviewed)
        [[ -z "${1:-}" ]] && { echo "tx reviewed <id>" >&2; exit 2; }
        call POST "/v1/transactions/$1/reviewed" \
          | emit '.data | "id=\(.id)  reviewedAt=\(.reviewedAt // "-")  needsReview=\(.needsReview)"'
        ;;
