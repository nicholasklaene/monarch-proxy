        fi
        ;;
      *)
        shift
        parse_flags "$@"
        call GET "/v1/recurring$(build_query)" | emit '.data.items[] | [.date, .account.displayName, .merchant.name, (.amount|tostring), (.isPast|tostring)] | @tsv' | fmt_table
