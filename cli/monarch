#!/usr/bin/env bash
# monarch - thin CLI over monarch-bridge HTTP service.
# Default gateway: http://localhost:9084 (override with MONARCH_GATEWAY env var).
# Bash 3.2 compatible (macOS default).
#
# Shared helpers (call, emit, fmt_table, parse_flags, etc.) live in
# `monarch-lib.sh` next to this script. Other bash scripts can source that file
# directly to talk to the bridge without re-implementing the HTTP plumbing.
set -euo pipefail

# Strip --raw flag (anywhere); set RAW=1 if present.
RAW=0
args=()
for a in "$@"; do
  if [[ "$a" == "--raw" ]]; then RAW=1; else args+=("$a"); fi
done
set -- "${args[@]+"${args[@]}"}"

# shellcheck source=monarch-lib.sh
# Resolve symlinks so monarch-lib.sh is found next to the REAL script even when
# this CLI is invoked through a symlink (e.g. ~/bin/monarch -> .../cli/monarch).
__src="${BASH_SOURCE[0]}"
while [ -h "$__src" ]; do
  __dir="$(cd -P "$(dirname "$__src")" && pwd)"
  __src="$(readlink "$__src")"
  case "$__src" in /*) ;; *) __src="$__dir/$__src" ;; esac
done
__dir="$(cd -P "$(dirname "$__src")" && pwd)"
source "$__dir/monarch-lib.sh"

usage() {
  cat <<'USAGE'
Usage: monarch <command> [--raw] [args...]

Read commands:
  health                                          Service + auth status
  auth [refresh]                                  Auth status (or refresh from disk)
  bootstrap                                       Interactive Monarch login inside the Docker
                                                  container (set MONARCH_CONTAINER to override
                                                  the container name; default 'monarch-bridge').
                                                  For repo installs use ./gradlew :app:bootstrapMonarch
  accounts                                        Linked accounts
  history <account-id>                            Per-account daily balance history
  holdings <account-id>                           Per-account investment positions
  transactions [--start --end --account-id --limit --offset --order-by FIELD]
               [--search TEXT] [--account ID]... [--category ID]... [--tag ID]...
               [--has-attachments T|F] [--has-notes T|F] [--hide-from-reports T|F]
               [--is-split T|F] [--is-recurring T|F] [--imported-from-mint T|F]
               [--synced-from-institution T|F] [--needs-review T|F]
               [--visibility hidden|all]
                                                  Transactions within a date window.
                                                  Results come NEWEST-FIRST. --start sets the
                                                  oldest-allowed date; pair with --end to bound
                                                  the upper side, or use --offset to page back
                                                  from the most recent. --order-by accepts
                                                  Monarch's TransactionOrdering values: 'date'
                                                  (default, by date desc) or 'amount' (largest
                                                  amount desc). Direction is fixed per field.
                                                  --account/--category/--tag are repeatable.
                                                  Bool flags accept T|F (also true/false/y/n/1/0).
                                                  --visibility: 'hidden' (only hidden) or 'all'
                                                  (hidden+visible); default is non-hidden only.
  cashflow [--start --end] [--search ...] [--account ID]... [--category ID]...
           [--tag ID]... [--has-attachments T|F] [--has-notes T|F]
           [--hide-from-reports T|F] [--is-split T|F] [--is-recurring T|F]
           [--imported-from-mint T|F] [--synced-from-institution T|F]
           [--needs-review T|F] [--visibility hidden|all]
                                                  Income/expense/savings aggregate
  networth [--start --end --account-type]         Aggregate balance history (all accounts)
  networth recent [--start]                       Recent per-account balance fluctuations
  networth by-type [--start --timeframe]          Balance history grouped by account type
  categories                                      Transaction categories
  category-groups                                 Top-level groups categories belong to
  tags                                            Transaction tags
  institutions                                    Linked institution credentials (Plaid pipes)
  account-types                                   Valid (type, subtype) combos for manual accounts
  subscription                                    Monarch subscription tier + payment source
  credit history                                  Credit-score snapshots (Spinwheel; empty if disabled)
  budgets [--start --end]                         Monthly budget + actuals for a window
  recurring [--start --end]                       Upcoming recurring transactions
  recurring all [--include-liabilities] [--include-pending]
                                                  All recurring streams with next-occurrence detail
  recurring streams [--include-liabilities]       Underlying recurring stream definitions
  recurring aggregate [--start --end]             Month-by-month aggregate recurring view
  paychecks [--start --end] [--owner ID] [--employer ID]
                                                  List paychecks within a window
  paycheck <id>                                   Single paycheck full detail
  paycheck summary [--start --end] [--employer ID] [--owner ID]...
                                                  Aggregate paycheck stats over a window
  paycheck-employers [--search Q] [--limit N] [--offset N]
                                                  List registered paycheck employers
  goals                                           List savings goals
  goal <id>                                       Single goal detail
  goal events <id>                                Event log for one savings goal
  goals totals [--start-month D] [--end-month D]  Current-month planned-contribution totals per goal
  merchants search [--q Q] [--limit N] [--offset N] [--with-logo] [--include-id ID]...
                                                  Search merchants by name (most-used first)
  merchant <id>                                   Merchant detail
  securities search <query> [--limit N] [--popularity]
                                                  Search Monarch's security catalog
  rules                                           List all transaction rules
  tx detail <id>                                  Full single-transaction detail
  tx splits <id>                                  Just the splits for one transaction
  tx summary [--start --end --account-id] [...TransactionFilterInput flags]
                                                  Aggregate count/sum/avg/min-max.
                                                  Accepts the same filter flags as `transactions`.
  tx duplicates --start D [--end D] [--account A] Groups of likely-duplicate transactions
  tx dashboard [--start --end --limit --offset] Lightweight transactions list with totals
                                                  + rule-count sidecar (dashboard widget shape).
  tx filter-accounts [--start --end]              Accounts that a transaction filter would touch
  tx review-summary                               Per-household-user review-queue counts
  tx explain <id>                                 AI rationale for one transaction (may be null)
  cashflow breakdown [--start --end] [...TransactionFilterInput flags]
                                                  Cashflow split by category / group / merchant.
                                                  Accepts the same filter flags as `cashflow`.
  cashflow dashboard --start --end                Day-by-day expense series
  cashflow entities --start --end                 Cashflow by category / category-group / merchant
                                                  plus a summary (sparser than `cashflow breakdown`)
  cashflow timeframe --start --end                Year / month / quarter cashflow summaries
  cashflow filtered --start --end [--account ID]... [--category ID]...
                    [--category-group ID]... [--merchant ID]... [--tag ID]...
                                                  Filterable cashflow: summary + 3 timeframe buckets
                                                  + category / group / merchant breakdowns
  recurring dashboard [--start --end] [--include-liabilities]
                                                  Upcoming items + remaining-due total ("next 30
                                                  days bills" widget shape)
  budgets month --month YYYY-MM-DD                Single-month per-category amounts (slim shape)
  budgets status                                  Has-budget / has-transactions status flags
  budget-status                                   Alias of `budgets status` for symmetry
  category edit <id>                              Category with full edit-form fields
  category deletion-info <id>                     Slim snapshot for the delete-confirm dialog
  category-group details <id> [--include-disabled-system]
                                                  Category group with its child categories
  portfolio allocation [--account ID]... [--classification F]
                                                  Allocation by classification (security type etc.)
  portfolio allocation by-account [--account ID]... [--limit N]
                                                  Allocation grouped per investments account
  portfolio allocation by-holdings [--account ID]... [--limit N]
                                                  Allocation grouped per holding (ticker)
  portfolio allocation holdings-detail --classification F --value V
                                                 [--account ID]... [--limit N] [--offset N]
                                                  Holdings inside one classification bucket
  security performance <id> [--start --end]       Per-day price history + cumulative return
  institution by-plaid <plaid-id>                 Institution lookup by Plaid id (e.g. ins_3)
  institutions top-groups [--provider P]...       Top institutions grouped by category
                                                  (providers: PLAID, FINICITY, MX)
  credentials                                     Lightweight linked-credentials list
  credentials with-institutions                   Credentials with full institution + provider data
  attachment <id>                                 Attachment detail (pre-signed download URL)
  insights [--status S]... [--start --end]        List AI savings insights (filter by status)
  insight <id>                                    Single insight detail (with playbook DIY steps)
  insights latest-run                             Latest insight-run metadata + total count
  recap weekly --start YYYY-MM-DD --end YYYY-MM-DD
                                                  Weekly AI recap (start=Monday, end=Sunday)
  refresh latest                                  Latest force-refresh request state
  refresh status                                  Per-account hasSyncInProgress flags
  balance-at <account-id> --date YYYY-MM-DD       Account display balance on a specific date
  balance-history status <session-key>            Poll parse status of a CSV upload session
  lookup <query>                                  Cross-entity fuzzy lookup (accounts, categories,
                                                  tags, merchants in one call)
  tax categories                                  All categories with systemCategory (tax-prep)
  tax aggregates [--start D] [--end D]            Sum + count by category for a date window
  tax mappings --schedule S --tax-year YYYY       Tax schedule line-item -> category mappings
  reports spending|income|net-worth|savings-rate|monthly-summary [--start D] [--end D]
                                                  Pre-aggregated reports family
  holding history <id> [--start --end]            Per-day value + quantity series for a holding
  security details <id>                           Security metadata (ticker, name, type, price)
  security dividends <id>                         Dividend history for one security
  merchant transactions <id> [--start --end]      All transactions for one merchant
  calendar events [--start --end]                 Bills + recurring + paychecks in calendar shape

Write commands (mutating; destructive ones require --yes):
  refresh [--wait [--timeout N]]                  Trigger Monarch to re-poll Plaid;
                                                  --wait blocks until every account finishes
                                                  (default 60s, max 300s)
  tx create --account A --date D --amount X --merchant M --category C [--notes N] [--update-balance]
                                                  Create a new transaction
  tx update <id> [--category C] [--merchant M] [--amount X] [--date D]
                 [--notes N] [--hide T|F] [--needs-review T|F] [--reviewed T|F] [--goal G]
                                                  Patch fields on a transaction
  tx delete <id> [--yes]                          Delete a transaction
  tx reviewed <id>                                Mark a transaction as reviewed (single-shot helper)
  tx tags <id> <tag-id>[,<tag-id>...]             Overwrite tag set on a transaction (empty = remove all)
  tx split <id> '<json-array>'                    Replace split allocations (sum must equal txn amount)
  tx attach <txn-id> <file-path>                  Upload a receipt photo or PDF as an attachment
  account create --type T --subtype S --name N [--balance B] [--no-net-worth]
                                                  Create a manual (non-Plaid) account
  account update <id> [--name N] [--balance B] [--type T] [--subtype S]
                      [--hide-from-list T|F] [--include-net-worth T|F] [--hide-from-reports T|F]
                                                  Patch account fields
  account delete <id> [--yes]                     Delete an account
  institution delete <cred-id> [--yes]            Unlink a Plaid credential (institution).
                                                  Use credential id from `monarch institutions`.
                                                  Soft-deletes linked accounts.
  account upload-balances <id> <csv-path> [--wait [--timeout N]]
                                                  Backfill balance history from CSV (header
                                                  date,balance). Returns a session key; --wait
                                                  blocks until status is completed or failed
                                                  (default 60s, max 300s)
  tag create <name> [--color #hex]                Create a new transaction tag
  tag delete <id> [--yes]                         Delete a tag (detaches from every transaction)
  category create <name> --group <group-id>
                          [--icon I] [--rollover-enabled] [--rollover-type T] [--rollover-start YYYY-MM-DD]
                                                  Create a custom category
  category delete <id> [--move-to <id>] [--yes]   Delete a category (optionally remap its txns)
  category delete-bulk <id1,id2,...> [--move-to <id>] [--yes]
                                                  Delete many categories in one call; per-id
                                                  failures returned in failed[] rather than 4xx
  budget set --start D --amount X (--category C | --category-group G) [--timeframe month] [--apply-future]
                                                  Set planned budget for one category OR
                                                  category-group for a month (amount 0 clears)
  budget flex --start D --amount X [--apply-future]
                                                  Update the Flex bucket total for a month
  budget flex-rollover --start D [--balance B] [--enabled T|F] [--system fixed_and_flex]
                                                  Configure / reset the Flex rollover period
  budget reset --start D [--yes]                  Reset all planned amounts for one month back
                                                  to defaults (destructive - needs --yes)
  merchant recurrence <id> --name N [--recurring T|F] [--frequency F] [--base-date D]
                                   [--amount X] [--active T|F]
                                                  Update a merchant's recurring-transaction
                                                  settings (name is REQUIRED - pass existing
                                                  display name if only changing recurrence)
  merchant delete <id> [--move-to <other-id>] [--yes]
                                                  Delete a merchant (optionally reassign txns first)
  merchant logo <id> --cloudinary-id ID|--clear   Point merchant at existing Cloudinary asset
                                                  (binary upload not supported by Monarch)
  paycheck create --employer ID --gross X --date D [--net X] [--period-start D] [--period-end D]
                  [--provider P] [--owner ID] [--deductions '<json>'] [--deposits '<json>']
                                                  Record a new paycheck. --deductions: array of
                                                  {deductionType,amount[,customDeductionName]};
                                                  --deposits: array of {transactionId} to link.
  paycheck update <id> [--employer ID] [--gross X] [--date D] [--period-start D]
                       [--period-end D] [--provider P] [--owner ID]
                       [--deductions '<json>'] [--deposits '<json>']
                                                  Patch fields on a paycheck (deductions/deposits
                                                  replace the existing sets)
  paycheck delete <id> [--yes]                    Delete a paycheck
  paycheck-employer create --name N               Register a new employer
  paycheck-employer update <id> --name N          Rename an employer
  paycheck-employer delete <id> [--yes]           Delete an employer (refuses if attached)
  holding add <account-id> --security-id ID --quantity Q
                                                  Add a manual holding to an account
  holding update <id> [--quantity Q] [--security-type T] [--basis X]
                                                  Partial-update a holding
  holding delete <id> [--yes]                     Delete a holding
  account create-investments --name N --subtype S [--tracking balances|holdings]
                                                  [--initial-balance X] [--initial-holdings '<json>']
                                                  Create a manual investments account
  account bulk-update '<json-array>'              Bulk-patch many accounts in one call.
                                                  Each entry: {id, ...patch fields}
  category-group create --name N --type expense|income|transfer
                                                  [--color C] [--icon I] [--variability V]
                                                  [--group-budgeting T|F] [--order-before ID]
                                                  Create a category group
  category-group update <id> [--name N] [--color C] [--icon I] [--variability V]
                              [--group-budgeting T|F] [--rollover-enabled T|F]
                              [--rollover-type T] [--rollover-start D]
                                                  Patch a category group
  category-group delete <id> [--move-to <other-id>] [--yes]
                                                  Delete a category group
  category-group budget-variability <id> --variability fixed|flexible|non_monthly
                                                  Set the fixed/flex classification
  goal create --name N [--type savings|debt] [--target X] [--target-date D]
              [--image-provider P --image-id ID]
                                                  Create a new savings goal
  goal update <id> [--name N] [--target X] [--target-date D] [--priority N]
                   [--sinking-fund T|F] [--image-provider P --image-id ID]
                                                  Partial-update a goal
  goal contribute <id> --account ID --amount X [--date D]
                                                  Record a contribution to a goal
  goal archive <id> [--yes]                       Archive (soft-delete) a goal
  goal unarchive <id> [--yes]                     Un-archive a goal
  goal delete <id> [--yes]                        Hard-delete a goal (irreversible)
  goal priorities <id1>,<id2>,<id3>               Re-order goals (index = priority)
  goal budget <id> --amount X [--month D] [--account ID] [--apply-future]
                                                  Set monthly budget allocation for a goal
  goal complete <id>                              Mark a goal as complete (v2 lifecycle)
  goal incomplete <id>                            Reverse a complete (back to active)
  goal spend <id> --amount X [--date D] [--notes N]
                                                  Log a spend event against goal balance
  goal withdraw <id> --amount X [--account ID] [--date D]
                                                  Withdraw goal balance back to source account
  rule create '<json>'                            Create a transaction rule (raw rule json)
  rule update <id> '<json>'                       Update a transaction rule (full shape)
  rule delete <id> [--yes]                        Delete a transaction rule
  rule preview '<json>' [--offset N]              Dry-run: matching txns + proposed values
  tx bulk-update --expected N --updates '<json>'
                 [--ids a,b,c | --all-selected [--exclude a,b,c] [--filters '<json>']]
                                                  Bulk-patch many transactions
  tx bulk-delete --expected N
                 [--ids a,b,c | --all-selected [--exclude a,b,c] [--filters '<json>']] [--yes]
                                                  Bulk-delete many transactions
  tx not-recurring <stream-id>                    Mark a recurring stream as not-recurring

Global flag:
  --raw    Print raw JSON (skip jq formatting)

Env:
  MONARCH_GATEWAY (default: http://localhost:9084)
USAGE
}

[[ $# -eq 0 ]] && { usage; exit 0; }

case "$1" in
  -h|--help|help) usage ;;

  health)
    call GET /healthz | emit '"\(.status)  authenticated=\(.authenticated)  lastVerifiedAt=\(.lastVerifiedAt // "-")"'
    ;;

  auth)
    if [[ "${2:-}" == "refresh" ]]; then
      call POST /v1/auth/refresh | emit '.'
    else
      call GET /v1/auth/status | emit '"authenticated=\(.authenticated)  email=\(.email // "-")  lastVerifiedAt=\(.lastVerifiedAt // "-")"'
    fi
    ;;

  bootstrap)
    # Interactive Monarch auth. Runs inside the Docker container so the captured
    # session token lands in the volume the service reads from.
    container="${MONARCH_CONTAINER:-monarch-bridge}"
    if ! command -v docker >/dev/null 2>&1; then
      echo "monarch bootstrap: docker not found on PATH." >&2
      echo "For a repo install, run interactive auth via Gradle instead:" >&2
      echo "  ./gradlew :app:bootstrapMonarch" >&2
      exit 1
    fi
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -qx "$container"; then
      echo "monarch bootstrap: container '$container' is not running." >&2
      echo "Start it first (docker compose up -d), or set MONARCH_CONTAINER to its name." >&2
      echo "For a repo install, run interactive auth via Gradle instead:" >&2
      echo "  ./gradlew :app:bootstrapMonarch" >&2
      exit 1
    fi
    exec docker exec -it "$container" java -jar /app/app.jar --bootstrap-monarch
    ;;

  accounts)
    call GET /v1/accounts \
      | emit '.data.accounts[]
              | [.id, .displayName, (.currentBalance|tostring),
                 ((.institution.name // "-")),
                 ((.type | if type == "object" then (.display // .name) else . end) // "-"),
                 (if .includeInNetWorth then "Y" else "N" end),
                 (if .hideFromList     then "Y" else "N" end)]
              | @tsv' \
      | fmt_table
    ;;

  history)
    [[ -z "${2:-}" ]] && { echo "monarch history <account-id>" >&2; exit 2; }
    call GET "/v1/account/$2/history" | emit '.data.snapshots | sort_by(.date) | "\(length) snapshots  first=\(.[0].date)  last=\(.[-1].date)  latest_balance=\(.[-1].signedBalance)"'
    ;;

  holdings)
    [[ -z "${2:-}" ]] && { echo "monarch holdings <account-id>" >&2; exit 2; }
    call GET "/v1/account/$2/holdings" | emit '.data.holdings[] | [(.ticker // .security.ticker // "-"), ((.totalQuantity // .quantity // 0)|tostring), ((.totalValue // 0)|tostring), ((.costBasis // .basis // 0)|tostring)] | @tsv' | fmt_table
    ;;

  transactions)
    shift
    parse_flags "$@"
    call GET "/v1/transactions$(build_query)" | emit '.data.results[] | [.date, .merchant.name, (.amount|tostring), .category.name] | @tsv' | fmt_table
    ;;

  cashflow)
    case "${2:-}" in
      breakdown)
        shift 2
        parse_flags "$@"
        call GET "/v1/cashflow/breakdown$(build_query)" | emit '.data | {summary: .summary, byCategory: ([.byCategory[] | {name: .groupBy.category.name, sum: .summary.sum}]), byCategoryGroup: ([.byCategoryGroup[] | {name: .groupBy.categoryGroup.name, sum: .summary.sum}]), byMerchant: ([.byMerchant[] | {name: .groupBy.merchant.name, sumIncome: .summary.sumIncome, sumExpense: .summary.sumExpense}])}'
        ;;
      dashboard)
        shift 2
        START=""; END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            *) echo "cashflow dashboard: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        path="/v1/cashflow/dashboard${q:+?${q:1}}"
        call GET "$path" \
          | emit '.data.byDay[] | [.day, ((.sumExpense // 0)|tostring)] | @tsv' \
          | fmt_table
        ;;
      entities)
        shift 2
        START=""; END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            *) echo "cashflow entities: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        path="/v1/cashflow/entities${q:+?${q:1}}"
        call GET "$path" | emit '.data | {summary: .summary, byCategory: ([.byCategory[] | {name: (.category.name // "-"), sum}]), byCategoryGroup: ([.byCategoryGroup[] | {name: (.categoryGroup.name // "-"), sum}]), byMerchant: ([.byMerchant[] | {name: (.merchant.name // "-"), sumIncome, sumExpense}])}'
        ;;
      timeframe)
        shift 2
        START=""; END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            *) echo "cashflow timeframe: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        path="/v1/cashflow/timeframe${q:+?${q:1}}"
        call GET "$path" | emit '.data | {byYear: ([.byYear[] | {period: .period, income: .sumIncome, expense: .sumExpense, savings: .savings, rate: .savingsRate}]), byMonth: ([.byMonth[] | {period: .period, income: .sumIncome, expense: .sumExpense, savings: .savings, rate: .savingsRate}]), byQuarter: ([.byQuarter[] | {period: .period, income: .sumIncome, expense: .sumExpense, savings: .savings, rate: .savingsRate}])}'
        ;;
      filtered)
        shift 2
        START=""; END=""; ACCOUNT_IDS=""; CATEGORY_IDS=""; CGROUP_IDS=""; MERCHANT_IDS=""; TAG_IDS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            --account) ACCOUNT_IDS="${ACCOUNT_IDS:+$ACCOUNT_IDS }$2"; shift 2 ;;
            --category) CATEGORY_IDS="${CATEGORY_IDS:+$CATEGORY_IDS }$2"; shift 2 ;;
            --category-group) CGROUP_IDS="${CGROUP_IDS:+$CGROUP_IDS }$2"; shift 2 ;;
            --merchant) MERCHANT_IDS="${MERCHANT_IDS:+$MERCHANT_IDS }$2"; shift 2 ;;
            --tag) TAG_IDS="${TAG_IDS:+$TAG_IDS }$2"; shift 2 ;;
            *) echo "cashflow filtered: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        # Note: cashflow-filtered uses singular param names (accountId, categoryId, etc.)
        # repeated, NOT the plural -Ids form used elsewhere.
        if [[ -n "$ACCOUNT_IDS" ]]; then
          for id in $ACCOUNT_IDS; do q+="&accountId=$id"; done
        fi
        if [[ -n "$CATEGORY_IDS" ]]; then
          for id in $CATEGORY_IDS; do q+="&categoryId=$id"; done
        fi
        if [[ -n "$CGROUP_IDS" ]]; then
          for id in $CGROUP_IDS; do q+="&categoryGroupId=$id"; done
        fi
        if [[ -n "$MERCHANT_IDS" ]]; then
          for id in $MERCHANT_IDS; do q+="&merchantId=$id"; done
        fi
        if [[ -n "$TAG_IDS" ]]; then
          for id in $TAG_IDS; do q+="&tagId=$id"; done
        fi
        path="/v1/cashflow/filtered${q:+?${q:1}}"
        call GET "$path" | emit '.data'
        ;;
      *)
        shift
        parse_flags "$@"
        call GET "/v1/cashflow$(build_query)" | emit '.data.summary | "income=\(.sumIncome)  expense=\(.sumExpense)  savings=\(.savings)  savingsRate=\(.savingsRate)"'
        ;;
    esac
    ;;

  networth)
    case "${2:-}" in
      recent)
        shift 2
        parse_flags "$@"
        call GET "/v1/networth/recent$(build_query)" | emit '.data.accounts[] | "\(.accountId)  recent=\(.recentBalances)"'
        ;;
      by-type)
        shift 2
        parse_flags "$@"
        call GET "/v1/networth/by-type$(build_query)" | emit '.data.snapshotsByAccountType[] | [.month, .accountType, (.balance|tostring)] | @tsv' | fmt_table
        ;;
      *)
