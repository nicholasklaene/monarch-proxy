        [[ -z "${1:-}" ]] && { echo "tx explain <id>" >&2; exit 2; }
        call GET "/v1/transactions/$1/explain" \
          | emit '.data | "explanation=\(.explanation // "-")"'
        ;;
      dashboard)
        START=""; END=""; LIMIT=""; OFFSET=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            --limit) LIMIT="$2"; shift 2 ;;
            --offset) OFFSET="$2"; shift 2 ;;
            *) echo "tx dashboard: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        [[ -n "$LIMIT" ]] && q+="&limit=$LIMIT"
        [[ -n "$OFFSET" ]] && q+="&offset=$OFFSET"
        path="/v1/transactions/dashboard${q:+?${q:1}}"
        resp=$(call GET "$path")
        if [[ "$RAW" == "1" ]]; then
          printf '%s' "$resp"
        else
          printf '%s\n' "$resp" | jq -r '.data | "totalCount=\(.totalCount // "-")  selectable=\(.totalSelectableCount // "-")  ruleCount=\(.ruleCount // "-")"'
          printf '%s\n' "$resp" | jq -r '.data.results[] | [.date, (.merchantName // .plaidName // "-"), ((.amount // 0)|tostring), (.categoryName // "-"), (.accountDisplayName // "-"), .id] | @tsv' | column -t -s $'\t'
        fi
        ;;
      filter-accounts)
        START=""; END=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            *) echo "tx filter-accounts: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        path="/v1/transactions/accounts-for-filter${q:+?${q:1}}"
        call GET "$path" \
          | emit '.data.accounts[] | [.id, (.displayName // "-"), (.typeDisplay // "-"), (.dataProvider // "-")] | @tsv' \
          | fmt_table
        ;;
      review-summary)
        call GET /v1/transactions/review-summary \
          | emit '.data.rows[] | [(.id // "-"), (.name // "-"), ((.count // 0)|tostring)] | @tsv' \
          | fmt_table
        ;;
      summary)
        parse_flags "$@"
        call GET "/v1/transactions/summary$(build_query)" | emit '.data.summary | "count=\(.count)  sumIncome=\(.sumIncome)  sumExpense=\(.sumExpense)  avg=\(.avg)  max=\(.max)  first=\(.first // "-")  last=\(.last // "-")"'
        ;;
      duplicates)
        # Accept --start/--end/--account (alias of --account-id). parse_flags handles
        # --account-id; rewrite --account to --account-id before delegating.
        rewritten=()
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --account) rewritten+=(--account-id "$2"); shift 2 ;;
            *) rewritten+=("$1"); shift ;;
          esac
        done
        set -- "${rewritten[@]+"${rewritten[@]}"}"
        parse_flags "$@"
        [[ -z "$START" ]] && { echo "tx duplicates requires --start YYYY-MM-DD" >&2; exit 2; }
        call GET "/v1/transactions/duplicates$(build_query)" \
          | emit '.data.groups[] as $g
                  | $g.transactions[]
                  | [($g.key.date // "-"),
                     (($g.key.amount // 0)|tostring),
                     ($g.key.merchantName // "-"),
                     (.account.displayName // "-"),
                     .id]
                  | @tsv' \
          | fmt_table
        ;;
      attach)
        [[ -z "${1:-}" || -z "${2:-}" ]] && { echo "tx attach <txn-id> <file-path>" >&2; exit 2; }
        TXID="$1"; FILE="$2"
        call_multipart POST "/v1/transactions/$TXID/attachments" file "$FILE" \
          | emit '.data.attachment
                  | "id=\(.id)  filename=\(.filename // "-")  ext=\(.extension // "-")  size=\(.sizeBytes // 0)  url=\(.originalAssetUrl // "-")"'
        ;;
      create)
        ACCOUNT=""; DATE=""; AMOUNT=""; MERCHANT=""; CATEGORY=""; NOTES=""; UPDATE_BAL="false"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --account) ACCOUNT="$2"; shift 2 ;;
            --date) DATE="$2"; shift 2 ;;
            --amount) AMOUNT="$2"; shift 2 ;;
            --merchant) MERCHANT="$2"; shift 2 ;;
            --category) CATEGORY="$2"; shift 2 ;;
            --notes) NOTES="$2"; shift 2 ;;
            --update-balance) UPDATE_BAL="true"; shift ;;
            *) echo "tx create: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$ACCOUNT" || -z "$DATE" || -z "$AMOUNT" || -z "$MERCHANT" || -z "$CATEGORY" ]] && {
          echo "tx create requires --account --date --amount --merchant --category" >&2; exit 2;
        }
        body=$(jq -n --arg acc "$ACCOUNT" --arg d "$DATE" --argjson amt "$AMOUNT" \
                     --arg m "$MERCHANT" --arg c "$CATEGORY" --arg n "$NOTES" --argjson ub "$UPDATE_BAL" \
          '{accountId:$acc,date:$d,amount:$amt,merchantName:$m,categoryId:$c,notes:$n,shouldUpdateBalance:$ub}')
        call POST /v1/transactions "$body" | emit ".data"
        ;;
      update)
        [[ -z "${1:-}" ]] && { echo "tx update <id> [flags]" >&2; exit 2; }
        TXID="$1"; shift
        CATEGORY=""; MERCHANT=""; AMOUNT=""; DATE=""; NOTES=""; HIDE=""; REVIEW=""; REVIEWED=""; GOAL=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --category) CATEGORY="$2"; shift 2 ;;
            --merchant) MERCHANT="$2"; shift 2 ;;
            --amount) AMOUNT="$2"; shift 2 ;;
            --date) DATE="$2"; shift 2 ;;
            --notes) NOTES="$2"; shift 2 ;;
            --hide) HIDE="$2"; shift 2 ;;
            --needs-review) REVIEW="$2"; shift 2 ;;
            --reviewed) REVIEWED="$2"; shift 2 ;;
            --goal) GOAL="$2"; shift 2 ;;
            *) echo "tx update: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        # NOTE: do NOT use `select(.!="")` *inside* an object value - it kills the
        # whole object (jq's `select` drops the entire surrounding context when the
        # condition is false). Use if/else null per field, then prune nulls outside.
        body=$(jq -n \
          --arg c "$CATEGORY" --arg m "$MERCHANT" --arg amt "$AMOUNT" --arg d "$DATE" \
          --arg n "$NOTES" --arg h "$HIDE" --arg r "$REVIEW" --arg rv "$REVIEWED" --arg g "$GOAL" \
          '{category:$c, name:$m,
            amount: (if $amt == "" then null else ($amt|tonumber) end),
            date:$d, notes:$n,
            hideFromReports: (if $h == "" then null else ($h|test("^(t|true|yes|1|y)$";"i")) end),
            needsReview:     (if $r == "" then null else ($r|test("^(t|true|yes|1|y)$";"i")) end),
            reviewed:        (if $rv == "" then null else ($rv|test("^(t|true|yes|1|y)$";"i")) end),
            goalId:$g}
           | with_entries(select(.value != "" and .value != null))')
        call PATCH "/v1/transactions/$TXID" "$body" | emit ".data"
        ;;
      delete)
        [[ -z "${1:-}" ]] && { echo "tx delete <id> [--yes]" >&2; exit 2; }
        TXID="$1"; shift
        [[ "${1:-}" == "--yes" ]] && YES=1
        confirm "Delete transaction $TXID?"
        call DELETE "/v1/transactions/$TXID" | emit ".data"
        ;;
      tags)
        [[ -z "${1:-}" || -z "${2:-}" ]] && { echo "tx tags <id> <tag-id>[,<tag-id>...]" >&2; exit 2; }
        TXID="$1"; CSV="$2"
        tag_ids_json=$(echo "$CSV" | jq -R 'if . == "" then [] else split(",") end')
        body=$(jq -n --argjson t "$tag_ids_json" '{tagIds:$t}')
        call PUT "/v1/transactions/$TXID/tags" "$body" | emit ".data"
        ;;
      split)
        [[ -z "${1:-}" || -z "${2:-}" ]] && { echo "tx split <id> '<json-array>'" >&2; exit 2; }
        TXID="$1"; SPLIT_JSON="$2"
        body=$(jq -n --argjson s "$SPLIT_JSON" '{splitData:$s}')
        call POST "/v1/transactions/$TXID/splits" "$body" | emit '.data'
        ;;
      bulk-update)
        EXPECTED=""; UPDATES=""; IDS=""; ALL_SELECTED=""; EXCLUDE=""; FILTERS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --expected) EXPECTED="$2"; shift 2 ;;
            --updates) UPDATES="$2"; shift 2 ;;
            --ids) IDS="$2"; shift 2 ;;
            --all-selected) ALL_SELECTED="true"; shift ;;
            --exclude) EXCLUDE="$2"; shift 2 ;;
            --filters) FILTERS="$2"; shift 2 ;;
            *) echo "tx bulk-update: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$EXPECTED" ]] && { echo "tx bulk-update requires --expected N (race-prevention guard)" >&2; exit 2; }
        [[ -z "$UPDATES" ]] && { echo "tx bulk-update requires --updates '<json>' (TransactionUpdateParams shape)" >&2; exit 2; }
        if [[ -z "$IDS" && -z "$ALL_SELECTED" ]]; then
          echo "tx bulk-update requires --ids a,b,c OR --all-selected" >&2; exit 2;
        fi
        ids_json="[]"
        [[ -n "$IDS" ]] && ids_json=$(echo "$IDS" | jq -R 'split(",")')
        excl_json="[]"
        [[ -n "$EXCLUDE" ]] && excl_json=$(echo "$EXCLUDE" | jq -R 'split(",")')
        all_json="false"
        [[ -n "$ALL_SELECTED" ]] && all_json="true"
        filters_json="null"
        [[ -n "$FILTERS" ]] && filters_json="$FILTERS"
        body=$(jq -n --argjson ids "$ids_json" --argjson excl "$excl_json" \
                     --argjson all "$all_json" --argjson exp "$EXPECTED" \
                     --argjson upd "$UPDATES" --argjson f "$filters_json" \
          '{selectedTransactionIds:$ids, excludedTransactionIds:$excl, allSelected:$all,
            expectedAffectedTransactionCount:$exp, updates:$upd, filters:$f}
           | with_entries(select(.value != null))')
        call PATCH /v1/transactions/bulk "$body" | emit ".data"
        ;;
      bulk-delete)
        EXPECTED=""; IDS=""; ALL_SELECTED=""; EXCLUDE=""; FILTERS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --expected) EXPECTED="$2"; shift 2 ;;
            --ids) IDS="$2"; shift 2 ;;
            --all-selected) ALL_SELECTED="true"; shift ;;
            --exclude) EXCLUDE="$2"; shift 2 ;;
            --filters) FILTERS="$2"; shift 2 ;;
            --yes) YES=1; shift ;;
            *) echo "tx bulk-delete: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$EXPECTED" ]] && { echo "tx bulk-delete requires --expected N (race-prevention guard)" >&2; exit 2; }
        if [[ -z "$IDS" && -z "$ALL_SELECTED" ]]; then
          echo "tx bulk-delete requires --ids a,b,c OR --all-selected" >&2; exit 2;
        fi
        ids_json="[]"
        [[ -n "$IDS" ]] && ids_json=$(echo "$IDS" | jq -R 'split(",")')
        excl_json="[]"
        [[ -n "$EXCLUDE" ]] && excl_json=$(echo "$EXCLUDE" | jq -R 'split(",")')
        all_json="false"
        [[ -n "$ALL_SELECTED" ]] && all_json="true"
        filters_json="null"
        [[ -n "$FILTERS" ]] && filters_json="$FILTERS"
        confirm "Bulk-delete $EXPECTED transactions? This is destructive."
        body=$(jq -n --argjson ids "$ids_json" --argjson excl "$excl_json" \
                     --argjson all "$all_json" --argjson exp "$EXPECTED" \
                     --argjson f "$filters_json" \
          '{selectedTransactionIds:$ids, excludedTransactionIds:$excl, allSelected:$all,
            expectedAffectedTransactionCount:$exp, filters:$f}
           | with_entries(select(.value != null))')
        call POST /v1/transactions/bulk-delete "$body" | emit ".data"
        ;;
      not-recurring)
        [[ -z "${1:-}" ]] && { echo "tx not-recurring <stream-id>  (pass the transaction's stream.id, NOT txn id)" >&2; exit 2; }
        SID="$1"
        call POST "/v1/transactions/$SID/not-recurring" | emit ".data"
        ;;
      *) echo "tx subcommands: create | update | delete | tags | split | detail | splits | summary | duplicates | attach | bulk-update | bulk-delete | not-recurring | reviewed | explain | dashboard | filter-accounts | review-summary" >&2; exit 2 ;;
    esac
    ;;

  # ---------------------------------------------------------------------------
  # Write: accounts
  # ---------------------------------------------------------------------------
  account)
    shift
    sub="${1:-}"
    [[ -z "$sub" ]] && { echo "monarch account <create|update|delete|upload-balances|create-investments|bulk-update> [args]" >&2; exit 2; }
    shift
    case "$sub" in
      create)
        TYPE=""; SUBTYPE=""; NAME=""; BALANCE="0"; INC_NW="true"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --type) TYPE="$2"; shift 2 ;;
            --subtype) SUBTYPE="$2"; shift 2 ;;
            --name) NAME="$2"; shift 2 ;;
            --balance) BALANCE="$2"; shift 2 ;;
            --no-net-worth) INC_NW="false"; shift ;;
            *) echo "account create: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$TYPE" || -z "$SUBTYPE" || -z "$NAME" ]] && {
          echo "account create requires --type --subtype --name" >&2; exit 2;
        }
        body=$(jq -n --arg t "$TYPE" --arg st "$SUBTYPE" --arg n "$NAME" \
                     --argjson b "$BALANCE" --argjson inw "$INC_NW" \
          '{type:$t,subtype:$st,name:$n,displayBalance:$b,includeInNetWorth:$inw}')
        call POST /v1/accounts "$body" | emit ".data"
        ;;
      update)
        [[ -z "${1:-}" ]] && { echo "account update <id> [flags]" >&2; exit 2; }
        AID="$1"; shift
        NAME=""; BALANCE=""; TYPE=""; SUBTYPE=""; HIDE_LIST=""; INC_NW=""; HIDE_REP=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --name) NAME="$2"; shift 2 ;;
            --balance) BALANCE="$2"; shift 2 ;;
            --type) TYPE="$2"; shift 2 ;;
            --subtype) SUBTYPE="$2"; shift 2 ;;
            --hide-from-list) HIDE_LIST="$2"; shift 2 ;;
            --include-net-worth) INC_NW="$2"; shift 2 ;;
            --hide-from-reports) HIDE_REP="$2"; shift 2 ;;
            *) echo "account update: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        # Same jq gotcha as tx update - use if/else null per field, not select(.!="").
        body=$(jq -n --arg n "$NAME" --arg b "$BALANCE" --arg t "$TYPE" --arg st "$SUBTYPE" \
                     --arg hl "$HIDE_LIST" --arg inw "$INC_NW" --arg hr "$HIDE_REP" \
          '{name:$n,
            displayBalance:               (if $b   == "" then null else ($b|tonumber) end),
            type:$t, subtype:$st,
            hideFromList:                 (if $hl  == "" then null else ($hl|test("^(t|true|yes|1|y)$";"i")) end),
            includeInNetWorth:            (if $inw == "" then null else ($inw|test("^(t|true|yes|1|y)$";"i")) end),
            hideTransactionsFromReports:  (if $hr  == "" then null else ($hr|test("^(t|true|yes|1|y)$";"i")) end)}
           | with_entries(select(.value != "" and .value != null))')
        call PATCH "/v1/accounts/$AID" "$body" | emit ".data"
        ;;
      delete)
        [[ -z "${1:-}" ]] && { echo "account delete <id> [--yes]" >&2; exit 2; }
        AID="$1"; shift
        [[ "${1:-}" == "--yes" ]] && YES=1
        confirm "Delete account $AID? This is destructive and removes all linked transactions."
        call DELETE "/v1/accounts/$AID" | emit ".data"
        ;;
      upload-balances)
        [[ -z "${1:-}" || -z "${2:-}" ]] && { echo "account upload-balances <id> <csv-path> [--wait [--timeout N]]" >&2; exit 2; }
        AID="$1"; CSV="$2"; shift 2
        WAIT=0; TIMEOUT=60
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --wait) WAIT=1; shift ;;
            --timeout) TIMEOUT="$2"; shift 2 ;;
            *) echo "account upload-balances: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        resp=$(call_multipart POST "/v1/accounts/$AID/balance-history" file "$CSV")
        if [[ "$WAIT" == "0" ]]; then
          printf '%s' "$resp" \
            | emit '.data | "sessionKey=\(.sessionKey)  status=\(.status)\nnext: monarch balance-history status \(.sessionKey)"'
          exit 0
        fi
        # --wait: poll the status endpoint until terminal state or timeout.
        SESSION=$(printf '%s' "$resp" | jq -r '.data.sessionKey')
        [[ -z "$SESSION" || "$SESSION" == "null" ]] && { echo "monarch: upload returned no sessionKey" >&2; exit 1; }
        elapsed=0
        status="pending"
        while [[ $elapsed -lt $TIMEOUT ]]; do
          status_resp=$(call GET "/v1/balance-history/$SESSION/status")
          status=$(printf '%s' "$status_resp" | jq -r '.data.status')
          case "$status" in
            completed|failed|error) break ;;
          esac
          sleep 2
          elapsed=$((elapsed + 2))
        done
        printf '{"data":{"sessionKey":"%s","status":"%s","elapsedSeconds":%d}}' "$SESSION" "$status" "$elapsed" \
          | emit '.data | "sessionKey=\(.sessionKey)  status=\(.status)  elapsedSeconds=\(.elapsedSeconds)"'
        case "$status" in
          completed) exit 0 ;;
          failed|error) exit 1 ;;
          *) echo "monarch: timeout after ${TIMEOUT}s (last status=$status)" >&2; exit 1 ;;
        esac
        ;;
      create-investments)
        NAME=""; SUBTYPE=""; TRACKING=""; INIT_BAL=""; INIT_HOLDINGS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --name) NAME="$2"; shift 2 ;;
            --subtype) SUBTYPE="$2"; shift 2 ;;
            --tracking) TRACKING="$2"; shift 2 ;;
            --initial-balance) INIT_BAL="$2"; shift 2 ;;
            --initial-holdings) INIT_HOLDINGS="$2"; shift 2 ;;
            *) echo "account create-investments: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$NAME" || -z "$SUBTYPE" ]] && {
          echo "account create-investments requires --name --subtype" >&2; exit 2;
        }
        holdings_json="null"
        [[ -n "$INIT_HOLDINGS" ]] && holdings_json="$INIT_HOLDINGS"
        body=$(jq -n --arg n "$NAME" --arg st "$SUBTYPE" --arg tr "$TRACKING" \
                     --arg ib "$INIT_BAL" --argjson ih "$holdings_json" \
          '{name:$n, subtype:$st,
            trackingMethod: (if $tr == "" then null else $tr end),
            initialBalance: (if $ib == "" then null else ($ib|tonumber) end),
            initialHoldings: $ih}
           | with_entries(select(.value != null))')
        call POST /v1/accounts/manual-investments "$body" | emit ".data"
        ;;
      bulk-update)
        [[ -z "${1:-}" ]] && { echo "account bulk-update '<json-array of {id, ...patches}>'" >&2; exit 2; }
        UPDATES_JSON="$1"
        body=$(jq -n --argjson u "$UPDATES_JSON" '{updates:$u}')
        call PATCH /v1/accounts/bulk "$body" | emit ".data"
        ;;
      *) echo "account subcommands: create | update | delete | upload-balances | create-investments | bulk-update" >&2; exit 2 ;;
    esac
    ;;

  # ---------------------------------------------------------------------------
  # Write: tags
  # ---------------------------------------------------------------------------
  tag)
    shift
    sub="${1:-}"
    [[ -z "$sub" ]] && { echo "monarch tag <create|delete> [args]" >&2; exit 2; }
    shift
    case "$sub" in
      create)
        [[ -z "${1:-}" ]] && { echo "tag create <name> [--color #hex]" >&2; exit 2; }
        TAG_NAME="$1"; shift
        COLOR="#999999"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --color) COLOR="$2"; shift 2 ;;
            *) echo "tag create: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        body=$(jq -n --arg n "$TAG_NAME" --arg c "$COLOR" '{name:$n,color:$c}')
        call POST /v1/tags "$body" | emit '.data'
        ;;
      delete)
        [[ -z "${1:-}" ]] && { echo "tag delete <id> [--yes]" >&2; exit 2; }
        TID="$1"; shift
        [[ "${1:-}" == "--yes" ]] && YES=1
        confirm "Delete tag $TID? It is detached from every transaction it was attached to."
        call DELETE "/v1/tags/$TID" | emit ".data"
        ;;
      *) echo "tag subcommands: create | delete" >&2; exit 2 ;;
    esac
    ;;

  # ---------------------------------------------------------------------------
  # Write: categories
  # ---------------------------------------------------------------------------
  category)
    shift
    sub="${1:-}"
    [[ -z "$sub" ]] && { echo "monarch category <create|delete|delete-bulk|edit|deletion-info> [args]" >&2; exit 2; }
    shift
    case "$sub" in
      edit)
        [[ -z "${1:-}" ]] && { echo "category edit <id>" >&2; exit 2; }
        call GET "/v1/categories/$1/edit" | emit '.data.category'
        ;;
      deletion-info)
        [[ -z "${1:-}" ]] && { echo "category deletion-info <id>" >&2; exit 2; }
        call GET "/v1/categories/$1/deletion-info" | emit '.data.category'
        ;;
      create)
        [[ -z "${1:-}" ]] && { echo "category create <name> --group <group-id> [flags]" >&2; exit 2; }
        CAT_NAME="$1"; shift
        GROUP=""; ICON="❓"; ROLL_EN="false"; ROLL_TYPE="monthly"; ROLL_START=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --group) GROUP="$2"; shift 2 ;;
            --icon) ICON="$2"; shift 2 ;;
            --rollover-enabled) ROLL_EN="true"; shift ;;
            --rollover-type) ROLL_TYPE="$2"; shift 2 ;;
            --rollover-start) ROLL_START="$2"; shift 2 ;;
            *) echo "category create: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$GROUP" ]] && { echo "category create requires --group <group-id>" >&2; exit 2; }
        [[ -z "$ROLL_START" ]] && ROLL_START=$(date +%Y-%m-01)
        body=$(jq -n --arg g "$GROUP" --arg n "$CAT_NAME" --arg i "$ICON" \
                     --argjson re "$ROLL_EN" --arg rt "$ROLL_TYPE" --arg rs "$ROLL_START" \
          '{group:$g,name:$n,icon:$i,rolloverEnabled:$re,rolloverType:$rt,rolloverStartMonth:$rs}')
        call POST /v1/categories "$body" | emit ".data"
        ;;
      delete)
        [[ -z "${1:-}" ]] && { echo "category delete <id> [--move-to <id>] [--yes]" >&2; exit 2; }
        CID="$1"; shift
        MOVE_TO=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --move-to) MOVE_TO="$2"; shift 2 ;;
            --yes) YES=1; shift ;;
            *) echo "category delete: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        confirm "Delete category $CID?${MOVE_TO:+ (transactions will be moved to $MOVE_TO)}"
        path="/v1/categories/$CID"
        [[ -n "$MOVE_TO" ]] && path="$path?moveToCategoryId=$MOVE_TO"
        call DELETE "$path" | emit ".data"
        ;;
      delete-bulk)
        [[ -z "${1:-}" ]] && { echo "category delete-bulk <id1,id2,...> [--move-to <id>] [--yes]" >&2; exit 2; }
        CSV="$1"; shift
        MOVE_TO=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --move-to) MOVE_TO="$2"; shift 2 ;;
            --yes) YES=1; shift ;;
            *) echo "category delete-bulk: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        ids_json=$(echo "$CSV" | jq -R 'if . == "" then [] else split(",") end')
        count=$(echo "$ids_json" | jq 'length')
        [[ "$count" -eq 0 ]] && { echo "category delete-bulk: no ids provided" >&2; exit 2; }
        confirm "Delete $count categories?${MOVE_TO:+ (transactions will be moved to $MOVE_TO)}"
        if [[ -n "$MOVE_TO" ]]; then
          body=$(jq -n --argjson ids "$ids_json" --arg m "$MOVE_TO" '{ids:$ids,moveToCategoryId:$m}')
        else
          body=$(jq -n --argjson ids "$ids_json" '{ids:$ids}')
        fi
        call POST /v1/categories/bulk-delete "$body" \
          | emit '.data | "deleted=\((.deleted // []) | length)  failed=\((.failed // []) | length)\n\((.failed // [])[] | "  failed \(.id): \(.reason)")"'
        ;;
      *) echo "category subcommands: create | delete | delete-bulk | edit | deletion-info" >&2; exit 2 ;;
    esac
    ;;

  # ---------------------------------------------------------------------------
  # Write: budgets (set/flex/flex-rollover/reset)
  # ---------------------------------------------------------------------------
  budget)
    shift
    sub="${1:-}"
    [[ -z "$sub" ]] && { echo "monarch budget <set|flex|flex-rollover|reset> [args]" >&2; exit 2; }
    shift
    case "$sub" in
      set)
        START=""; AMOUNT=""; CAT=""; CGRP=""; TIMEFRAME=""; APPLY_FUTURE="false"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --amount) AMOUNT="$2"; shift 2 ;;
            --category) CAT="$2"; shift 2 ;;
            --category-group) CGRP="$2"; shift 2 ;;
            --timeframe) TIMEFRAME="$2"; shift 2 ;;
            --apply-future) APPLY_FUTURE="true"; shift ;;
            *) echo "budget set: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$START" || -z "$AMOUNT" ]] && {
          echo "budget set requires --start --amount" >&2; exit 2;
        }
        if [[ -n "$CAT" && -n "$CGRP" ]] || [[ -z "$CAT" && -z "$CGRP" ]]; then
          echo "budget set requires exactly one of --category or --category-group" >&2; exit 2;
        fi
        body=$(jq -n --arg s "$START" --argjson a "$AMOUNT" \
                     --arg c "$CAT" --arg g "$CGRP" --arg tf "$TIMEFRAME" --argjson af "$APPLY_FUTURE" \
          '{amount:$a, startDate:$s,
            categoryId:      (if $c  == "" then null else $c  end),
            categoryGroupId: (if $g  == "" then null else $g  end),
            timeframe:       (if $tf == "" then null else $tf end),
            applyToFuture:$af}
           | with_entries(select(.value != null))')
