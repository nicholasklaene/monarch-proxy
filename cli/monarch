  # ---------------------------------------------------------------------------
  # Write: transactions
  # ---------------------------------------------------------------------------
  tx)
    shift
    sub="${1:-}"
    [[ -z "$sub" ]] && { echo "monarch tx <create|update|delete|tags|split|detail|splits|summary|duplicates|attach|bulk-update|bulk-delete|not-recurring|reviewed|explain|dashboard|filter-accounts|review-summary> [args]" >&2; exit 2; }
    shift
    case "$sub" in
      detail)
