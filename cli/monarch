    ;;

  paycheck)
    shift
    sub="${1:-}"
    [[ -z "$sub" ]] && { echo "monarch paycheck <id|summary|create|update|delete> [args]" >&2; exit 2; }
    case "$sub" in
      summary)
        shift
        START=""; END=""; EMPLOYER=""; OWNER_IDS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --start) START="$2"; shift 2 ;;
            --end) END="$2"; shift 2 ;;
            --employer) EMPLOYER="$2"; shift 2 ;;
            --owner) OWNER_IDS="${OWNER_IDS:+$OWNER_IDS }$2"; shift 2 ;;
            *) echo "paycheck summary: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        q=""
        [[ -n "$START" ]] && q+="&start=$START"
        [[ -n "$END" ]] && q+="&end=$END"
        [[ -n "$EMPLOYER" ]] && q+="&employerId=$EMPLOYER"
        if [[ -n "$OWNER_IDS" ]]; then
          for id in $OWNER_IDS; do q+="&ownerIds=$id"; done
        fi
        path="/v1/paychecks/summary${q:+?${q:1}}"
        call GET "$path" | emit '.data'
        ;;
      create)
        shift
        EMPLOYER=""; GROSS=""; DATE=""; NET=""; P_START=""; P_END=""; PROVIDER=""; OWNER=""; DEDUCTIONS=""; DEPOSITS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --employer) EMPLOYER="$2"; shift 2 ;;
            --gross) GROSS="$2"; shift 2 ;;
            --date) DATE="$2"; shift 2 ;;
            --net) NET="$2"; shift 2 ;;
            --period-start) P_START="$2"; shift 2 ;;
            --period-end) P_END="$2"; shift 2 ;;
            --provider) PROVIDER="$2"; shift 2 ;;
            --owner) OWNER="$2"; shift 2 ;;
            --deductions) DEDUCTIONS="$2"; shift 2 ;;
            --deposits) DEPOSITS="$2"; shift 2 ;;
            *) echo "paycheck create: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        [[ -z "$EMPLOYER" || -z "$GROSS" || -z "$DATE" ]] && {
          echo "paycheck create requires --employer --gross --date" >&2; exit 2;
        }
        # NOTE: --net is informational here; Monarch derives net from deposits.
        # We accept the flag but warn rather than send it as a top-level field.
        [[ -n "$NET" ]] && echo "monarch: --net is ignored on create (Monarch derives net from deposits)" >&2
        body=$(jq -n --arg e "$EMPLOYER" --argjson g "$GROSS" --arg d "$DATE" \
                     --arg ps "$P_START" --arg pe "$P_END" --arg p "$PROVIDER" --arg o "$OWNER" \
                     --argjson ded "${DEDUCTIONS:-null}" --argjson dep "${DEPOSITS:-null}" \
          '{employerId:$e, grossAmount:$g, payDate:$d,
            payPeriodStart: (if $ps == "" then null else $ps end),
            payPeriodEnd:   (if $pe == "" then null else $pe end),
            payrollProvider:(if $p  == "" then null else $p  end),
            ownerId:        (if $o  == "" then null else $o  end),
            deductions:     $ded,
            deposits:       $dep}
           | with_entries(select(.value != null))')
        call POST /v1/paychecks "$body" | emit ".data"
        ;;
      update)
        shift
        [[ -z "${1:-}" ]] && { echo "paycheck update <id> [flags]" >&2; exit 2; }
        PID="$1"; shift
        EMPLOYER=""; GROSS=""; DATE=""; P_START=""; P_END=""; PROVIDER=""; OWNER=""; DEDUCTIONS=""; DEPOSITS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --employer) EMPLOYER="$2"; shift 2 ;;
            --gross) GROSS="$2"; shift 2 ;;
            --date) DATE="$2"; shift 2 ;;
            --period-start) P_START="$2"; shift 2 ;;
            --period-end) P_END="$2"; shift 2 ;;
            --provider) PROVIDER="$2"; shift 2 ;;
            --owner) OWNER="$2"; shift 2 ;;
            --deductions) DEDUCTIONS="$2"; shift 2 ;;
            --deposits) DEPOSITS="$2"; shift 2 ;;
            *) echo "paycheck update: unknown flag: $1" >&2; exit 2 ;;
          esac
        done
        body=$(jq -n --arg e "$EMPLOYER" --arg g "$GROSS" --arg d "$DATE" \
                     --arg ps "$P_START" --arg pe "$P_END" --arg p "$PROVIDER" --arg o "$OWNER" \
                     --argjson ded "${DEDUCTIONS:-null}" --argjson dep "${DEPOSITS:-null}" \
          '{employerId:     (if $e  == "" then null else $e  end),
            grossAmount:    (if $g  == "" then null else ($g|tonumber) end),
            payDate:        (if $d  == "" then null else $d  end),
            payPeriodStart: (if $ps == "" then null else $ps end),
            payPeriodEnd:   (if $pe == "" then null else $pe end),
            payrollProvider:(if $p  == "" then null else $p  end),
            ownerId:        (if $o  == "" then null else $o  end),
            deductions:     $ded,
            deposits:       $dep}
           | with_entries(select(.value != null))')
        call PATCH "/v1/paychecks/$PID" "$body" | emit ".data"
        ;;
      delete)
        shift
        [[ -z "${1:-}" ]] && { echo "paycheck delete <id> [--yes]" >&2; exit 2; }
        PID="$1"; shift
        [[ "${1:-}" == "--yes" ]] && YES=1
        confirm "Delete paycheck $PID?"
        call DELETE "/v1/paychecks/$PID" | emit ".data"
        ;;
      *)
        # Treat first positional as an id (paycheck <id> detail).
        PID="$sub"
        call GET "/v1/paychecks/$PID" | emit '.data.paycheck'
        ;;
    esac
    ;;

  paycheck-employers)
