root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{kt,kts,java}]
indent_size = 4
max_line_length = 140
# NOTE: the wrapping rules (argument-list-wrapping / parameter-list-wrapping / wrapping)
# are disabled in `config/detekt/detekt.yml` because spotless ktfmt is the authoritative
# formatter and the two formatters disagree on how to wrap. They're NOT disabled here
# because other ktlint rules depend on them — disabling via .editorconfig breaks rule
# loading in spotless's bundled ktlint with "Skipping rule(s) which are depending on
# a rule which is not loaded" errors. The detekt-only disable is sufficient.

[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab
